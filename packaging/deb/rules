#!/usr/bin/make -f

%:
	dh $@ --with python3,systemd

override_dh_auto_build:
	python3 -m build --wheel --no-isolation

override_dh_auto_test:
	# Skip test

override_dh_auto_install:
	# Instal dari wheel ke folder root sistem debian
	python3 -m pip install --root=$(CURDIR)/debian/superscaler --no-deps --ignore-installed --no-warn-script-location dist/*.whl

override_dh_auto_clean:
	dh_auto_clean
	rm -rf dist/ build/ src/*.egg-info/ superscaler.egg-info/