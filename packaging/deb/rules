#!/usr/bin/make -f

%:
	dh $@ --with python3

override_dh_auto_build:
	python3 -m build --wheel --no-isolation

override_dh_auto_test:
	# Skip test

override_dh_auto_install:
	python3 -m pip install --root=$(CURDIR)/debian/superscaler --prefix=/usr --no-deps --ignore-installed --no-warn-script-location dist/*.whl
	if [ -d $(CURDIR)/debian/superscaler/usr/local ] ; then \
		cp -a $(CURDIR)/debian/superscaler/usr/local/* $(CURDIR)/debian/superscaler/usr/ ; \
		rm -rf $(CURDIR)/debian/superscaler/usr/local ; \
	fi

override_dh_auto_clean:
	dh_auto_clean
	rm -rf dist/ build/ src/*.egg-info/ superscaler.egg-info/